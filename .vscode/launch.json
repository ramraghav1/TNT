{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "TNT Server (HTTPS)",
            "type": "coreclr",
            "request": "launch",
            "program": "${workspaceFolder}/server/bin/Debug/net10.0/server.dll",
            "args": [],
            "cwd": "${workspaceFolder}/server",
            "stopAtEntry": false,
            "preLaunchTask": "build",
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development",
                "ASPNETCORE_URLS": "https://localhost:7236;http://localhost:5295"
            },
            "console": "internalConsole"
        },
        {
            "name": "TNT Server (HTTP)",
            "type": "coreclr",
            "request": "launch",
            "program": "${workspaceFolder}/server/bin/Debug/net10.0/server.dll",
            "args": [],
            "cwd": "${workspaceFolder}/server",
            "stopAtEntry": false,
            "preLaunchTask": "build",
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development",
                "ASPNETCORE_URLS": "http://localhost:5295"
            },
            "console": "internalConsole"
        }
    ]
}
